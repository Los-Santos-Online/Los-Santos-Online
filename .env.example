# Core server configuration
DOMAIN="dev.lossantosonline.com"
SERVER_SECRET="replace-with-a-64-character-random-hex-value"

# External relay advertised to game clients
RELAY_PUBLIC_ADDRESS="51.81.86.255"
RELAY_PUBLIC_PORT=6677

# Saves and stats R2 bucket
S3_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
S3_ACCESS_KEY="replace-with-saves-r2-access-key"
S3_SECRET_KEY="replace-with-saves-r2-secret-key"
S3_BUCKET_NAME="los-santos-online-saves"

# UGC R2 bucket
S3_UGC_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
S3_UGC_ACCESS_KEY="replace-with-ugc-r2-access-key"
S3_UGC_SECRET_KEY="replace-with-ugc-r2-secret-key"
S3_UGC_BUCKET_NAME="los-santos-online-ugc"

# Optional Discord bot. Leave blank to disable it.
DISCORD_TOKEN=""
DISCORD_GUILD_ID=""
